# Node Server Configuration
PORT=5000
SESSION_SECRET=super-secret-key-tekathon5

# Google Sheets Configuration
SPREADSHEET_ID=your_spreadsheet_id_here
# Note: You also need a credentials.json file in the root directory for Google Sheets auth

# Google Drive Configuration (Optional but recommended)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# NodeMailer SMTP Email Configuration
# Use your Gmail address and an "App Password" (not your main password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
